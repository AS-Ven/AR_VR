# =========================
# Unity generated folders
# =========================
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
UserSettings/

# MemoryCaptures can get huge (especially in VR profiling)
MemoryCaptures/

# =========================
# Unity cache & metadata
# =========================
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd

# Unity meta files SHOULD be tracked
!*.meta

# =========================
# Visual Studio / Rider
# =========================
.vs/
.vscode/
.idea/
*.mdb
*.opendb
*.VC.db

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# Crash reports
# =========================
sysinfo.txt

# =========================
# Addressables
# =========================
ServerData/

# =========================
# Unity Addressable build cache
# =========================
Library/com.unity.addressables/

# =========================
# XR / VR specific
# =========================

# Oculus / OpenXR generated files
Assets/Plugins/Android/*.aar
Assets/Plugins/Android/*.jar

# StreamingAssets (keep tracked EXCEPT generated content if needed)
# Uncomment if you generate runtime data:
# Assets/StreamingAssets/generated/

# XR build artifacts
Assets/XR/Build/

# =========================
# IL2CPP
# =========================
Library/Il2cppBuildCache/

# =========================
# Android / Quest builds
# =========================
*.apk
*.aab
*.obb

# Gradle
.gradle/
ExportedProject/

# =========================
# iOS builds
# =========================
*.ipa
*.xcworkspace
*.xcuserdata/

# =========================
# Shader cache (can explode in VR projects)
# =========================
Library/ShaderCache/

# =========================
# Profiling captures (VR = heavy files)
# =========================
*.data
*.raw
*.trace

# =========================
# Packages (keep manifest, ignore cache)
# =========================
Packages/packages-lock.json

# =========================
# DOTS / Entities cache
# =========================
Library/DOTS/

# =========================
# JetBrains Rider plugin
# =========================
Assets/Plugins/Editor/JetBrains*

# =========================
# Misc
# =========================
*.log